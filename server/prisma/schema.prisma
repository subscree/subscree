generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum BillingCycle {
    YEARLY
    MONTHLY
    WEEKLY
    DAILY
}

enum SubscriptionStatus {
    ACTIVE
    CANCELLED
    PAUSED
    TRIAL
}

enum NotificationMode {
    PER_SUBSCRIPTION
    DIGEST
}

enum DigestFrequency {
    WEEKLY
    MONTHLY
}

enum TeamRole {
    OWNER
    MEMBER
}

model User {
    id                String          @id @default(uuid())
    email             String          @unique
    passwordHash      String
    name              String
    preferredCurrency String          @default("USD")

    // Entities this user created (ownership is by team; this is "created by")
    subscriptions     Subscription[]
    categories        Category[]
    paymentMethods    PaymentMethod[]

    // Teams
    memberships  TeamMember[]
    activeTeamId String?
    activeTeam   Team?       @relation("ActiveTeam", fields: [activeTeamId], references: [id], onDelete: SetNull)
    reminderLogs ReminderLog[]

    // Payment reminder notifications
    notifyEnabled         Boolean          @default(false)
    notifyMode            NotificationMode @default(PER_SUBSCRIPTION)
    notifyDaysBefore      Int              @default(3)
    notifyDigestFrequency DigestFrequency  @default(WEEKLY)
    lastDigestSentAt      DateTime?

    // Password reset
    resetTokenHash      String?
    resetTokenExpiresAt DateTime?

    createdAt         DateTime        @default(now())
    updatedAt         DateTime        @updatedAt
}

model Team {
    id             String           @id @default(uuid())
    name           String
    members        TeamMember[]
    invitations    TeamInvitation[]
    subscriptions  Subscription[]
    categories     Category[]
    paymentMethods PaymentMethod[]
    activeForUsers User[]           @relation("ActiveTeam")
    createdAt      DateTime         @default(now())
    updatedAt      DateTime         @updatedAt
}

model TeamMember {
    id        String   @id @default(uuid())
    teamId    String
    team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    role      TeamRole @default(MEMBER)
    createdAt DateTime @default(now())

    @@unique([teamId, userId])
}

model TeamInvitation {
    id          String   @id @default(uuid())
    teamId      String
    team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
    email       String
    role        TeamRole @default(MEMBER)
    tokenHash   String   @unique
    expiresAt   DateTime
    invitedById String?
    createdAt   DateTime @default(now())

    @@index([email])
    @@index([teamId])
}

model PaymentMethod {
    id            String         @id @default(uuid())
    teamId        String
    team          Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
    userId        String
    user          User           @relation(fields: [userId], references: [id])
    name          String
    type          String         @default("card")
    logoUrl       String?
    subscriptions Subscription[]
    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt

    @@index([teamId])
}

model Subscription {
    id              String            @id @default(uuid())
    teamId          String
    team            Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
    userId          String
    user            User              @relation(fields: [userId], references: [id])
    name            String
    url             String?
    logoUrl         String?
    categories      Category[]
    paymentMethodId String?
    paymentMethod   PaymentMethod?    @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
    amount          Float
    currency        String
    billingCycle    BillingCycle
    status          SubscriptionStatus
    startDate       DateTime?
    nextBillingDate DateTime?
    cancelledAt     DateTime?
    notes           String?
    reminderLogs    ReminderLog[]
    createdAt       DateTime          @default(now())
    updatedAt       DateTime          @updatedAt

    @@index([teamId])
}

// One row per (user, subscription, billing occurrence) reminder sent, so each
// team member who enabled reminders is notified exactly once per charge.
model ReminderLog {
    id             String       @id @default(uuid())
    userId         String
    user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
    subscriptionId String
    subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
    billingDate    DateTime
    createdAt      DateTime     @default(now())

    @@unique([userId, subscriptionId, billingDate])
    @@index([subscriptionId])
}

model Category {
    id            String         @id @default(uuid())
    name          String
    subscriptions Subscription[]
    teamId        String
    team          Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
    userId        String
    user          User           @relation(fields: [userId], references: [id])
    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt

    @@index([teamId])
}
