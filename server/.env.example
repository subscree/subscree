PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/nook
JWT_SECRET=your_jwt_secret_here_minimum_32_chars
ORIGIN_URL=http://localhost:3001

# Public URL of the web app, used in email links (falls back to ORIGIN_URL)
APP_URL=http://localhost:3001

# Email delivery — configure ONE provider. Resend takes priority if both are set.
# If neither is configured, emails are logged to the console and the notification
# scheduler stays disabled.
EMAIL_FROM="Nook <no-reply@nook.app>"

# Option A: Resend (https://resend.com)
RESEND_API_KEY=

# Option B: SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Notification scheduler poll interval in ms (default 1h)
NOTIFY_INTERVAL_MS=3600000
